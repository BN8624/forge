{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "canon_review.schema.json",
  "title": "Forge canon compliance review",
  "type": "object",
  "required": ["story_sha256", "overall_pass", "verdicts"],
  "properties": {
    "story_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "overall_pass": {
      "type": "boolean"
    },
    "verdicts": {
      "type": "array",
      "minItems": 21,
      "maxItems": 21,
      "items": {
        "type": "object",
        "required": ["canon_id", "status", "scene_ids", "reason"],
        "properties": {
          "canon_id": {
            "type": "string",
            "pattern": "^C([1-9]|1[0-9]|2[01])$"
          },
          "status": {
            "enum": ["pass", "fail", "uncertain"]
          },
          "scene_ids": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^V[1-5]-E[0-9]{2}-S[0-9]{2}$"
            }
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
