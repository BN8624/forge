{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "prose_review.schema.json",
  "title": "Forge prose scene review",
  "type": "object",
  "required": [
    "scene_id",
    "status",
    "checks",
    "issues",
    "reason",
    "prose_sha256",
    "scene_contract_sha256"
  ],
  "properties": {
    "scene_id": {
      "type": "string",
      "pattern": "^V[1-5]-E[0-9]{2}-S[0-9]{2}$"
    },
    "status": {
      "enum": ["pass", "fail", "uncertain"]
    },
    "checks": {
      "type": "object",
      "required": [
        "objective",
        "state_transition",
        "owned_elements",
        "reveal_order",
        "canon",
        "continuity",
        "prose_quality"
      ],
      "properties": {
        "objective": {"type": "boolean"},
        "state_transition": {"type": "boolean"},
        "owned_elements": {"type": "boolean"},
        "reveal_order": {"type": "boolean"},
        "canon": {"type": "boolean"},
        "continuity": {"type": "boolean"},
        "prose_quality": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "issues": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "prose_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "scene_contract_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "additionalProperties": false
}
